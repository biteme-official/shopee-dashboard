# Shopee Partner API 설정
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

SHOPEE_PARTNER_ID=0
SHOPEE_PARTNER_KEY=your_partner_key_here
SHOPEE_SHOP_ID=0

# 토큰 (shopee_tokens.json 대신 여기에 입력 가능)
SHOPEE_TOKENS_JSON={"access_token":"...","refresh_token":"...","expire_time":0}

# 아래는 기본값이 있어 생략 가능
# SHOPEE_HOST=https://partner.shopeemobile.com
# SHOPEE_TOKEN_FILE=shopee_tokens.json
